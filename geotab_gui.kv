#:kivy 2.3.1
#:set border_width 50

<CustomPopup@Popup>:
    title: "Información"
    size_hint: (0.8, 0.6)
    auto_dismiss: True
    
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 15
        
        Label:
            text: "[b]Control de Luces Geotab[/b]"
            markup: True
            font_size: "18sp"
            size_hint_y: 0.2
        
        Label:
            text: "[b]Desarrollado por:[/b]\nLuis Manrique\nJosé André Paredes"
            markup: True
            size_hint_y: 0.3
        
        Label:
            text: "[b]Contacto:[/b]\nlmanriqu@fmi.com\njparedes5@fmi.com"
            markup: True
            size_hint_y: 0.3
        
        Label:
            text: "[b]Versión:[/b] 1.0.0"
            markup: True
            size_hint_y: 0.2
        
        Button:
            text: "Cerrar"
            size_hint_y: 0.3
            on_release: root.dismiss()

<BoxLayout>:
    canvas.before:
        Color:
            rgba: 0, 0, 0, 1
        Rectangle:
            pos: self.pos
            size: self.size

BoxLayout:
    orientation: "vertical"
    
    # Header con logo y título
    BoxLayout:
        size_hint_y: 0.15
        padding: 10
        spacing: 10
        
        # Logo        
        AsyncImage:
            source: 'logo.png'
            size_hint_x: 0.2
            allow_stretch: True
            keep_ratio: True
        
        # Título
        Label:
            text: "[b]CONTROL DE\nILUMINACIÓN[/b]"
            markup: True
            font_size: "18sp"
            halign: "center"
            size_hint_x: 0.6
        
        # Botón de información (solo la imagen)
        Button:
            size_hint_x: 0.2
            background_normal: ''
            background_color: 0, 0, 0, 1
            on_release: app.show_info_popup()
            
            AsyncImage:
                source: 'info.png'
                size: self.parent.width * 0.6, self.parent.height * 0.6
                pos: self.parent.center_x - (self.parent.width * 0.3), self.parent.center_y - (self.parent.height * 0.3)
                allow_stretch: True
                keep_ratio: True
    
    # Área de estado
    Label:
        id: status
        text: "Status: Ready"
        size_hint_y: 0.1
        color: 0.5, 0.5, 0.5, 1
    
    # Tabla de control con 4 botones tipo interruptor
    GridLayout:
        cols: 2
        padding: 20
        spacing: border_width
        size_hint_y: 0.7
        
        # Primera fila - Títulos (reducido a 0.05)
        Label:
            text: "[b]GENERADOR[/b]"
            markup: True
            font_size: "14sp"
            color: 0.9, 0.9, 0.9, 1
            size_hint_y: 0.05
        
        Label:
            text: "[b]LUCES[/b]"
            markup: True
            font_size: "14sp"
            color: 0.9, 0.9, 0.9, 1
            size_hint_y: 0.05
        
        # Segunda fila - Botones ON
        Button:
            id: btn_gen_on
            text: "ON"
            background_color: 0.2, 0.4, 0.2, 1
            color: 0.9, 0.9, 0.9, 1
            background_normal: ''
            font_size: "20sp"
            size_hint_y: 0.475
            
            canvas.after:
                Color:
                    rgba: 0, 0, 0, 1
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, border_width)
                    width: border_width/2
            
            on_release: 
                app.send_action("gen_on")
                # Solo afecta al par GENERADOR
                root.ids.btn_gen_on.background_color = (0.3, 1, 0.3, 1)
                root.ids.btn_gen_on.color = (0.1, 0.1, 0.1, 1)
                root.ids.btn_gen_off.background_color = (0.4, 0.2, 0.2, 1)
                root.ids.btn_gen_off.color = (0.9, 0.9, 0.9, 1)
                # Habilitar botones de LUCES (volver a estado inicial)
                root.ids.btn_light_on.disabled = False
                root.ids.btn_light_off.disabled = False
                root.ids.btn_light_on.background_color = (0.2, 0.4, 0.2, 1)
                root.ids.btn_light_on.color = (0.9, 0.9, 0.9, 1)
                root.ids.btn_light_off.background_color = (0.4, 0.2, 0.2, 1)
                root.ids.btn_light_off.color = (0.9, 0.9, 0.9, 1)
        
        Button:
            id: btn_light_on
            text: "ON"
            background_color: 0.2, 0.4, 0.2, 1
            color: 0.9, 0.9, 0.9, 1
            background_normal: ''
            font_size: "20sp"
            size_hint_y: 0.475
            disabled: False
            
            canvas.after:
                Color:
                    rgba: 0, 0, 0, 1
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, border_width)
                    width: border_width/2
            
            on_release: 
                app.send_action("light_on")
                # Solo afecta al par LUCES
                root.ids.btn_light_on.background_color = (0.3, 1, 0.3, 1)
                root.ids.btn_light_on.color = (0.1, 0.1, 0.1, 1)
                root.ids.btn_light_off.background_color = (0.4, 0.2, 0.2, 1)
                root.ids.btn_light_off.color = (0.9, 0.9, 0.9, 1)
        
        # Tercera fila - Botones OFF
        Button:
            id: btn_gen_off
            text: "OFF"
            background_color: 0.4, 0.2, 0.2, 1
            color: 0.9, 0.9, 0.9, 1
            background_normal: ''
            font_size: "20sp"
            size_hint_y: 0.475
            
            canvas.after:
                Color:
                    rgba: 0, 0, 0, 1
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, border_width)
                    width: border_width/2
            
            on_release: 
                app.send_action("gen_off")
                # Solo afecta al par GENERADOR
                root.ids.btn_gen_off.background_color = (1, 0.3, 0.3, 1)
                root.ids.btn_gen_off.color = (0.1, 0.1, 0.1, 1)
                root.ids.btn_gen_on.background_color = (0.2, 0.4, 0.2, 1)
                root.ids.btn_gen_on.color = (0.9, 0.9, 0.9, 1)
                # Deshabilitar botones de LUCES y ponerlos grises
                root.ids.btn_light_on.disabled = True
                root.ids.btn_light_off.disabled = True
                root.ids.btn_light_on.background_color = (0.3, 0.3, 0.3, 1)
                root.ids.btn_light_on.color = (0.5, 0.5, 0.5, 1)
                root.ids.btn_light_off.background_color = (0.3, 0.3, 0.3, 1)
                root.ids.btn_light_off.color = (0.5, 0.5, 0.5, 1)
        
        Button:
            id: btn_light_off
            text: "OFF"
            background_color: 0.4, 0.2, 0.2, 1
            color: 0.9, 0.9, 0.9, 1
            background_normal: ''
            font_size: "20sp"
            size_hint_y: 0.475
            disabled: False
            
            canvas.after:
                Color:
                    rgba: 0, 0, 0, 1
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, border_width)
                    width: border_width/2
            
            on_release: 
                app.send_action("light_off")
                # Solo afecta al par LUCES
                root.ids.btn_light_off.background_color = (1, 0.3, 0.3, 1)
                root.ids.btn_light_off.color = (0.1, 0.1, 0.1, 1)
                root.ids.btn_light_on.background_color = (0.2, 0.4, 0.2, 1)
                root.ids.btn_light_on.color = (0.9, 0.9, 0.9, 1)